POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
DATABASE_URL="postgresql://joot:CHANGE_ME@localhost:5432/joot"
REDIS_URL="redis://:CHANGE_ME@localhost:6379"
BETTER_AUTH_SECRET=CHANGE_ME_32_CHARS_MIN
BETTER_AUTH_URL=http://localhost:4000

# Public URL of the app — included in email links
APP_URL=https://joot.hazaa.co.za

# SMTP — for pilot use any SMTP server (Gmail, corporate mail, etc.)
# For production swap these for Resend/Postmark/SendGrid SMTP credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=Joot Leave <noreply@example.com>

# Seed script — only needed when running `docker compose --profile tools run --rm seed`
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=System Admin
HOLDING_COMPANY_NAME=Joot Holdings
SUBSIDIARY_NAME=Main Subsidiary
